{
  "name": "the-dmz",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "minimatch@>=3.0.0 <3.1.3": ">=3.1.3",
      "minimatch@>=5.0.0 <5.1.8": ">=5.1.8",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7",
      "minimatch@>=10.0.0 <10.2.1": ">=10.2.1"
    }
  },
  "scripts": {
    "predev": "node scripts/dev-preflight.mjs",
    "dev": "turbo run dev --parallel --filter=@the-dmz/web --filter=@the-dmz/api",
    "dev:web": "pnpm --filter @the-dmz/web dev",
    "dev:api": "pnpm --filter @the-dmz/api dev",
    "dev:services": "docker compose up -d",
    "build": "turbo run build",
    "lint": "turbo run lint && pnpm exec eslint playwright.config.ts e2e --max-warnings=0",
    "lint:fix": "turbo run lint:fix && pnpm exec eslint playwright.config.ts e2e --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "pnpm test:scripts && turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "test:coverage": "turbo run test:coverage",
    "test:e2e:prepare": "pnpm --filter @the-dmz/shared build",
    "test:e2e": "pnpm run test:e2e:prepare && playwright test",
    "test:e2e:ui": "pnpm run test:e2e:prepare && playwright test --ui",
    "test:e2e:headed": "pnpm run test:e2e:prepare && playwright test --headed",
    "test:e2e:debug": "pnpm run test:e2e:prepare && playwright test --debug",
    "test:a11y": "pnpm run test:e2e:prepare && playwright test e2e/smoke/accessibility-m1.spec.ts",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "env:setup": "node scripts/copy-env.mjs",
    "db:migrate": "pnpm --filter @the-dmz/api db:migrate",
    "db:seed": "pnpm --filter @the-dmz/api db:seed",
    "db:seed:test": "pnpm --filter @the-dmz/api db:seed:test",
    "db:seed:m1": "pnpm --filter @the-dmz/api db:seed:m1",
    "db:reset": "pnpm --filter @the-dmz/api db:reset",
    "services:up": "docker compose up -d",
    "services:down": "docker compose down",
    "services:reset": "docker compose down -v && docker compose up -d",
    "services:logs": "docker compose logs -f",
    "services:monitoring:up": "docker compose --profile monitoring up -d",
    "services:monitoring:down": "docker compose --profile monitoring down",
    "test:scripts": "node --test scripts/*.test.mjs",
    "storybook": "pnpm --filter @the-dmz/web storybook",
    "storybook:build": "turbo run storybook:build",
    "openapi:generate": "pnpm --filter @the-dmz/api openapi:generate",
    "openapi:check": "pnpm --filter @the-dmz/api openapi:check",
    "contract:parity": "pnpm --filter @the-dmz/api contract:parity",
    "mfa:parity": "pnpm --filter @the-dmz/api test -- --run src/modules/auth/__tests__/mfa-contract-drift.test.ts && pnpm --filter @the-dmz/web test -- --run src/lib/api/error-mapping-coverage.test.ts",
    "mfa:smoke": "pnpm --filter @the-dmz/api test -- --run src/modules/auth/__tests__/mfa-smoke.test.ts",
    "mfa:gate": "pnpm mfa:parity && pnpm mfa:smoke",
    "error-contract:check": "pnpm --filter @the-dmz/shared test -- --run src/constants/error-contract.test.ts && pnpm --filter @the-dmz/web test -- --run src/lib/api/error-mapping-coverage.test.ts",
    "test:load": "npx k6 run tests/load/scenarios/auth-storm.js",
    "test:load:auth": "npx k6 run tests/load/scenarios/auth-storm.js",
    "test:load:session": "npx k6 run tests/load/scenarios/game-session.js",
    "test:load:email": "npx k6 run tests/load/scenarios/email-triage.js",
    "test:load:ws": "npx k6 run tests/load/scenarios/websocket.js",
    "test:load:mixed": "npx k6 run tests/load/scenarios/mixed-workload.js",
    "test:load:sustained": "npx k6 run tests/load/scenarios/sustained-load.js",
    "test:load:degradation": "npx k6 run tests/load/scenarios/degradation.js",
    "test:load:all": "pnpm test:load:auth && pnpm test:load:session && pnpm test:load:mixed"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.50.1",
    "@secretlint/secretlint-rule-pattern": "^11.3.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.1",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-svelte": "^3.14.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "postgres": "^3.4.5",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "secretlint": "^11.3.1",
    "svelte-eslint-parser": "^1.4.1",
    "turbo": "^2.0.0"
  }
}
