{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "The DMZ",
  "version": "0.1.0",
  "identifier": "com.thedmz.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "The DMZ: Archive Gate",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$LOCALAPPDATA/**", "$HOME/.local/share/the-dmz/**"],
        "deny": []
      }
    },
    "store": {},
    "window-state": {
      "denylist": []
    },
    "log": {
      "level": "info",
      "targets": [
        { "kind": "stdout" },
        { "kind": "logDir", "name": "the-dmz", "rotationStrategy": "daily" }
      ]
    }
  }
}
